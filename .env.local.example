# Sanity CMS (obté el projectId a https://sanity.io/manage)
NEXT_PUBLIC_SANITY_PROJECT_ID=el_teu_project_id
NEXT_PUBLIC_SANITY_DATASET=production

# Contrasenya per accedir com a administrador del calendari
CALENDARI_ADMIN_PASSWORD=la_teva_contrasenya_secreta

# Clau secreta per la sessió (genera una amb: openssl rand -hex 32)
CALENDARI_ADMIN_SECRET=una_clau_aleatoria_larga_i_secreta

# Resend - per enviar emails del formulari de lloguer (https://resend.com)
RESEND_API_KEY=re_xxxxx
# IMPORTANT per evitar SPAM: Verifica el teu domini a Resend i fes servir un email propi.
# onboarding@resend.dev pot anar a spam. Afegeix aquesta variable amb un email verificat:
# RESEND_FROM_EMAIL=contacte@escoltesiguies.cat
